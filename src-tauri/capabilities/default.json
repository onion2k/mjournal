{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$APPDATA/**",
          "app": "Visual Studio Code"
        },
        {
          "path": "$APPDATA/**",
          "app": "code"
        },
        {
          "path": "$APPDATA/**",
          "app": "code.cmd"
        },
        {
          "path": "$APPDATA/**",
          "app": "code.exe"
        }
      ]
    }
  ]
}
